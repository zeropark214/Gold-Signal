PORT=3001
GOLD_API_KEY=your_goldapi_key
GOLD_API_SYMBOL=XAU
GOLD_API_CURRENCY=USD
GOLD_API_DATE=
# GoldAPI 키가 없으면 COMEX 금 선물(GC=F) 실제 시세를 사용합니다.
FRED_API_KEY=your_fred_api_key
DATA_GO_KR_SERVICE_KEY=your_data_go_kr_service_key
NEWS_API_KEY=your_newsapi_key
GNEWS_API_KEY=your_gnews_key
GOOGLE_TRANSLATE_API_KEY=your_google_translate_key
MYMEMORY_EMAIL=your_email_for_translation_quota
NEWS_QUERY=(gold OR bullion OR "Federal Reserve" OR FOMC OR Powell OR "Kevin Warsh" OR "interest rates" OR "rate cut" OR PCE OR CPI OR inflation OR "Treasury yields" OR "US dollar" OR "dollar index" OR DXY OR Trump OR tariff OR sanctions OR Iran OR Israel OR Gaza OR "Middle East")
NEWS_PAGE_SIZE=10
NEWS_MIN_SCORE=60
NEWS_FETCH_TIMEOUT_MS=7000
GDELT_ENABLED=true
GDELT_QUERY=(gold OR bullion OR "central bank") (rate OR purchase OR reserve OR tariff OR sanction OR import OR inflation OR yen OR dollar)
OFFICIAL_NEWS_FEEDS_JSON=[{"name":"Federal Reserve","url":"https://www.federalreserve.gov/feeds/press_monetary.xml"},{"name":"Federal Reserve Speeches","url":"https://www.federalreserve.gov/feeds/speeches.xml"}]
LSEG_NEWS_CLIENT_ID=your_lseg_client_id
LSEG_NEWS_CLIENT_SECRET=your_lseg_client_secret
